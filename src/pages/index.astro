---
export const prerender = true;
const target = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/en/research`;
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
  </head>
  <body></body>
</html>